# =============================================================================
# MIRAX Ecosistema — STAGING (copia in .env.local, NON committare)
# Progetto Supabase DEV separato — MAI usare le chiavi di produzione.
# =============================================================================

# --- Supabase DEV (progetto ecosistema mirax) ---
NEXT_PUBLIC_SUPABASE_URL=https://ktspchugdwpqvxhmysap.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_dev_service_role_key

# --- Backend staging Hetzner 116 ---
BACKEND_URL=http://116.203.137.39:8002

# --- App URL (locale o Vercel preview) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic / paid extraction ---
# Fail-closed: la chiave da sola NON abilita spesa. Abilita solo in canary,
# con budget basso, dopo test locali verdi.
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_EXTRACT_ENABLED=0
MIRAX_LLM_MAX_REQUESTS_PER_JOB=3
MIRAX_LLM_MAX_COST_USD_PER_JOB=0.03
MIRAX_LLM_INPUT_USD_PER_M=3
MIRAX_LLM_OUTPUT_USD_PER_M=15
AGENTIC_PAGE_TIMEOUT_MS=8000
AGENTIC_NAV_TIMEOUT_MS=12000

# Emergency brakes: leave ON until preflight/canary passes.
MIRAX_WORKER_DISABLED=1
MIRAX_SEARCH_DISABLED=1

# --- Email (opzionale in dev) ---
RESEND_API_KEY=
RESEND_FROM=

# --- Stripe (usa TEST mode keys, non live) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Cron Vercel (generato da scripts/setup-vercel-ecosistema.mjs) ---
CRON_SECRET=

# --- Salesforce OAuth (opzionale) ---
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=

GOOGLE_PAGESPEED_API_KEY=
GOOGLE_PLACES_API_KEY=
OPENAPI_IT_TOKEN=
RAPIDAPI_KEY=

# --- Universe Knowledge Graph (sidecar, default OFF) ---
UNIVERSE_ENABLED=0
UNIVERSE_READ_ENABLED=0
NEXT_PUBLIC_UNIVERSE_UI=true
NEXT_PUBLIC_UNIVERSE_REALTIME=true
UNIVERSE_CACHE_ENABLED=0
UNIVERSE_ALERTS_ENABLED=0
UNIVERSE_CACHE_TTL_ANALYTICS=120
UNIVERSE_CACHE_TTL_AGENTIC=300
UNIVERSE_WEBHOOKS_ENABLED=0
UNIVERSE_EVENTS_ARCHIVE_DAYS=180
