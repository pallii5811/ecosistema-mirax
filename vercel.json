{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/reaudit",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-events",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/sequences-dispatch",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/knowledge-feed",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/website-change-detect",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/ops/worker-health",
      "schedule": "0 5 * * *"
    }
  ]
}
