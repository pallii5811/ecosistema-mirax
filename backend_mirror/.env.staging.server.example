# Staging environment — copy to /home/worker/app/backend-staging/.env on server 116
# NEVER use production Supabase credentials here.

SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_dev_service_role_key
DEMO_MAX_RESULTS=50
ENRICH_BUSINESS_EVENTS=1
ENRICH_BUSINESS_EVENTS_MAX=12
ORGANIC_DISCOVERY_ENABLED=1
ORGANIC_DISCOVERY_MAX_SITES=20
ORGANIC_AUDIT_MAX_SITES=16
USER_RECENT_MINUTES=0
UNIVERSE_ENABLED=0
UNIVERSE_READ_ENABLED=0
