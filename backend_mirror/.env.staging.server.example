# Staging environment — copy to /home/worker/app/backend-staging/.env on server 116
# NEVER use production Supabase credentials here.

SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_dev_service_role_key
DEMO_MAX_RESULTS=50
ENRICH_BUSINESS_EVENTS=1
ENRICH_BUSINESS_EVENTS_MAX=12
ORGANIC_DISCOVERY_ENABLED=1
ORGANIC_DISCOVERY_MAX_SITES=20
ORGANIC_AUDIT_MAX_SITES=16
USER_RECENT_MINUTES=0
UNIVERSE_ENABLED=0
UNIVERSE_READ_ENABLED=0

# Agentic discovery (planner + query gen + page extraction)
AGENTIC_GAP_FILL_ENABLED=1
AGENTIC_PAGE_TIMEOUT_MS=8000
AGENTIC_NAV_TIMEOUT_MS=12000

# Paid LLM extraction is fail-closed: an API key alone is not enough to spend.
ANTHROPIC_EXTRACT_ENABLED=0
MIRAX_LLM_MAX_REQUESTS_PER_JOB=3
MIRAX_LLM_MAX_COST_USD_PER_JOB=0.03
MIRAX_LLM_INPUT_USD_PER_M=3
MIRAX_LLM_OUTPUT_USD_PER_M=15

# Emergency brake. Keep at 1 until preflight/canary passes.
MIRAX_WORKER_DISABLED=1
